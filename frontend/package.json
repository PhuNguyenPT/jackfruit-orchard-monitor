{
  "name": "frontend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "clean:js": "rm -rf public/chunks public/*.min.js",
    "build": "npm run minify:css && npm run lint && npm run clean:js && npm run bundle:js",
    "minify:css": "npx tailwindcss -i ./public/styles/index.css -o ./public/output.css --minify",
    "bundle:js": "npx esbuild 'public/scripts/*.js' --bundle --minify --splitting --format=esm --outdir=public --entry-names=[name].min --chunk-names=chunks/[name]-[hash]",
    "lint": "eslint public/scripts/**/*.js",
    "lint:fix": "eslint public/scripts/**/*.js --fix",
    "fmt": "prettier --write public/scripts/**/*.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "chart.js": "^4.5.1",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "terser": "^5.46.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "@parcel/watcher@2.5.1": true
  }
}
