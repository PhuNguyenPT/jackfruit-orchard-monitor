---
# Disable everything first, then strictly enable the best-practice groups
Checks: >
  -*,
  bugprone-*,
  cert-*,
  cppcoreguidelines-*,
  modernize-*,
  performance-*,
  readability-*,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -readability-magic-numbers

WarningsAsErrors: ''
HeaderFilterRegex: '^(include|src)/.*'
FormatStyle: 'file'
...