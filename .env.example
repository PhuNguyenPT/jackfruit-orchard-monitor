# Application Configuration
PORT=8080                          # HTTP plain port (used when TLS disabled)
APP_ENV=dev                        # dev | production | test
APP_NAME=Prizm
# APP_VERSION=latest               # Docker image tag used by docker-compose; injected via ldflags at build time
GIN_MODE=debug                     # debug | release  (match APP_ENV: dev→debug, prod→release)
LOG_LEVEL=debug                    # debug | info | warn | error
BASE_URLS=["https://yourdomain.com"]  # JSON array; first entry is canonical URL

# PostgreSQL Database Configuration
POSTGRES_VERSION=18                # postgres Docker image tag (used by docker-compose)
POSTGRES_HOST=localhost            # Docker Compose service name (e.g. psql) or host IP
POSTGRES_PORT=5432
POSTGRES_DATABASE=goapp
POSTGRES_USERNAME=your_username
POSTGRES_PASSWORD=your_password    # min 8 characters
POSTGRES_SCHEMA=public

# Pagination
PAGE_SIZE=20
MAX_PAGE_SIZE=100

# mTLS Configuration
# Paths to TLS cert/key/CA — defaults to Docker secrets paths if omitted
TLS_CERT_PATH=/run/secrets/go_crt
TLS_KEY_PATH=/run/secrets/go_key
TLS_CA_PATH=/run/secrets/backend_ca
TLS_PORT=8443                      # HTTPS listener port

# MQTT Broker
MQTT_TLS_PORT=8883                 # TLS listener (always on)
MQTT_PORT=1883                     # Plain TCP listener; set to 0 to disable in production
MQTT_USER=esp32
MQTT_PASS=your_mqtt_password       # min 8 characters
MQTT_CERT_PATH=/run/secrets/go_crt # dedicated MQTT cert; falls back to TLS_CERT_PATH in production if unset
MQTT_KEY_PATH=/run/secrets/go_key  # dedicated MQTT key; falls back to TLS_KEY_PATH in production if unset
SOIL_DRY_VALUE=3500                # ADC raw value at 0% moisture (sensor calibration)
SOIL_WET_VALUE=1760                # ADC raw value at 100% moisture (sensor calibration)

# Contact
CONTACT_EMAIL=info@yourdomain.com
CONTACT_PHONE=+84 123 456 789