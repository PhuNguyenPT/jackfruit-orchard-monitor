# Application Configuration
PORT=8080
APP_ENV=dev
GIN_MODE=debug

# PostgreSQL Database Configuration
POSTGRES_VERSION=18
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=goapp
POSTGRES_USERNAME=your_username
POSTGRES_PASSWORD=your_password
POSTGRES_SCHEMA=public

# Pagination
PAGE_SIZE=20
MAX_PAGE_SIZE=100

# mTLS Configuration (optional — defaults to Docker secrets paths)
# TLS_CERT_PATH=/run/secrets/go_crt
# TLS_KEY_PATH=/run/secrets/go_key
# TLS_CA_PATH=/run/secrets/backend_ca
TLS_PORT=8443